{
  "version": 2,
  "name": "zohar-intelligence-dashboard",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/cloud-projects",
      "destination": "/api/cloud-projects.js"
    },
    {
      "source": "/api/cloud-analytics",
      "destination": "/api/cloud-analytics.js"
    },
    {
      "source": "/api/cloud-status",
      "destination": "/api/status.js"
    },
    {
      "source": "/api/:path*",
      "destination": "https://khaki-nails-make.loca.lt/api/:path*"
    }
  ]
}
