{
  "version": 2,
  "name": "zohar-agent",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/status",
      "destination": "https://puny-meals-strive.loca.lt/api/status"
    },
    {
      "source": "/api/agent_state",
      "destination": "https://puny-meals-strive.loca.lt/api/agent_state"
    },
    {
      "source": "/api/projects",
      "destination": "https://puny-meals-strive.loca.lt/api/projects"
    },
    {
      "source": "/api/analytics",
      "destination": "https://puny-meals-strive.loca.lt/api/analytics"
    },
    {
      "source": "/api/logs",
      "destination": "https://puny-meals-strive.loca.lt/api/logs"
    },
    {
      "source": "/api/control",
      "destination": "https://puny-meals-strive.loca.lt/api/control"
    },
    {
      "source": "/api/audit",
      "destination": "https://puny-meals-strive.loca.lt/api/audit"
    },
    {
      "source": "/api/diagnostics",
      "destination": "https://puny-meals-strive.loca.lt/api/diagnostics"
    },
    {
      "source": "/(.*)",
      "destination": "/dashboard/$1"
    }
  ]
}
