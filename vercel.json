{
  "version": 2,
  "name": "zohar-agent",
  "type": "module",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/cloud-projects",
      "destination": "/api/cloud-projects"
    },
    {
      "source": "/api/cloud-analytics",
      "destination": "/api/cloud-analytics"
    },
    {
      "source": "/api/cloud-status",
      "destination": "/api/cloud-status"
    },
    {
      "source": "/api/(status|agent_state|projects|analytics|logs|control|audit|diagnostics)",
      "destination": "https://puny-meals-strive.loca.lt/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/dashboard/$1"
    }
  ]
}
