{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "builds": [
    { "src": "index.py", "use": "@vercel/python" },
    { "src": "dashboard/**", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "index.py" },
    { "source": "/(.*)", "destination": "dashboard/$1" }
  ]
}
